{
  "name": "publa",
  "version": "0.1.42",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "config": {
    "tag-version-prefix": "release-v"
  },
  "scripts": {
    "test:unit": "npm run db:check-migrations && vitest --watch=false",
    "test:pg": "npm run db:check-migrations && vitest run src/server/services/postgres.contract.test.ts",
    "test:e2e": "NEXT_PUBLIC_E2E=1 next build && NEXT_PUBLIC_E2E=1 playwright test",
    "test": "npm run lint && npm run test:unit && npm run test:e2e",
    "dev": "next dev -p 8084",
    "build": "next build",
    "start": "next start",
    "lint": "eslint ./src ./e2e --max-warnings 0",
    "lint:fix": "eslint ./src ./e2e --fix --max-warnings 0",
    "db:generate": "npm run db:generate:sqlite",
    "db:generate:sqlite": "drizzle-kit generate --config=drizzle.sqlite.config.ts",
    "db:generate:pg": "drizzle-kit generate --config=drizzle.pg.config.ts",
    "db:generate:all": "npm run db:generate:sqlite && npm run db:generate:pg",
    "db:migrate": "npm run db:migrate:sqlite",
    "db:migrate:sqlite": "drizzle-kit migrate --config=drizzle.sqlite.config.ts",
    "db:migrate:pg": "drizzle-kit migrate --config=drizzle.pg.config.ts",
    "db:check-migrations": "node scripts/check-migration-chain.mjs",
    "db:seed": "tsx src/server/db/seed.ts",
    "db:studio": "drizzle-kit studio --config=drizzle.sqlite.config.ts",
    "check:i18n-runtime": "node scripts/check-i18n-runtime.mjs",
    "check:error-leaks": "node scripts/check-api-message-leaks.mjs",
    "check:ci-guard": "npm run check:i18n-runtime && npm run check:error-leaks",
    "version": "node scripts/sync-version.mjs && git add src/version.json"
  },
  "overrides": {
    "@tiptap/core": "3.23.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1045.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-markdown": "^6.5.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@libsql/client": "^0.17.3",
    "@mantine/charts": "^9.2.0",
    "@mantine/core": "^9.2.0",
    "@mantine/dates": "^9.2.0",
    "@mantine/dropzone": "^9.2.0",
    "@mantine/hooks": "^9.2.0",
    "@mantine/modals": "^9.2.0",
    "@mantine/notifications": "^9.2.0",
    "@mantine/tiptap": "^9.2.0",
    "@tabler/icons-react": "^3.44.0",
    "@tiptap/extension-code-block-lowlight": "^3.23.2",
    "@tiptap/extension-image": "^3.23.2",
    "@tiptap/extension-link": "^3.23.2",
    "@tiptap/extension-mathematics": "^3.23.2",
    "@tiptap/extension-placeholder": "^3.23.2",
    "@tiptap/extension-table": "^3.23.2",
    "@tiptap/react": "^3.23.2",
    "@tiptap/starter-kit": "^3.23.2",
    "@types/turndown": "^5.0.6",
    "@uiw/codemirror-theme-vscode": "^4.25.9",
    "@uiw/react-codemirror": "^4.25.9",
    "ahooks": "^3.9.7",
    "ali-oss": "^6.23.0",
    "animate.css": "^4.1.1",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cookies": "^0.9.1",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.45.2",
    "feed": "^5.2.1",
    "fflate": "^0.8.2",
    "highlight.js": "^11.11.1",
    "jose": "^6.2.3",
    "js-base64": "^3.7.8",
    "js-cookie": "^3.0.5",
    "katex": "^0.16.45",
    "lodash": "^4.18.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.14.0",
    "markdown-it": "^14.1.1",
    "markdown-it-imsize": "^2.0.1",
    "markdown-it-mathjax": "^2.0.0",
    "nanoid": "^5.1.11",
    "next": "^16.2.6",
    "next-intl": "^4.11.2",
    "nextjs-progressbar": "^0.0.16",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "postcss-preset-mantine": "^1.18.0",
    "qs": "^6.15.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.75.0",
    "react-icons": "^5.6.0",
    "react-virtuoso": "^4.18.7",
    "recharts": "^3.8.1",
    "resend": "^6.12.3",
    "sanitize-html": "^2.17.3",
    "svg-captcha": "^1.4.0",
    "sweetalert2": "^11.26.24",
    "toad-scheduler": "^4.0.1",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@playwright/test": "^1.60.0",
    "@types/ali-oss": "^6.23.3",
    "@types/js-cookie": "^3.0.6",
    "@types/katex": "^0.16.8",
    "@types/lodash": "^4.17.24",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.7.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/qs": "^6.15.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "autoprefixer": "^10.5.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
